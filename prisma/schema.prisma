generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  avatarColor String   @default("#6366f1")
  createdAt   DateTime @default(now())

  sessions      Session[]
  workspaces    WorkspaceMember[]
  assignedTasks Task[]            @relation("TaskAssignee")
  createdTasks  Task[]            @relation("TaskCreator")
  comments      TaskComment[]
  retroCards    RetroCard[]
  objectives    Objective[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())

  members WorkspaceMember[]
  spaces  Space[]
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  role        String   @default("member")
  userId      String
  workspaceId String
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Space {
  id              String   @id @default(cuid())
  name            String
  color           String   @default("#6366f1")
  icon            String   @default("📁")
  methodologyType String   @default("kanban")
  workspaceId     String
  createdAt       DateTime @default(now())

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lists       TaskList[]
  statuses    TaskStatus[]
  sprints     Sprint[]
  objectives  Objective[]
  canvasCards CanvasCard[]
  retroCards  RetroCard[]

  @@index([workspaceId])
}

model TaskStatus {
  id      String @id @default(cuid())
  name    String
  color   String
  order   Int
  type    String @default("active")
  spaceId String

  space Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([spaceId])
}

model TaskList {
  id      String @id @default(cuid())
  name    String
  order   Int    @default(0)
  spaceId String

  space Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([spaceId])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  priority    String    @default("normal")
  dueDate     DateTime?
  order       Int       @default(0)
  storyPoints Int?
  listId      String
  statusId    String
  sprintId    String?
  assigneeId  String?
  creatorId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  list     TaskList    @relation(fields: [listId], references: [id], onDelete: Cascade)
  status   TaskStatus  @relation(fields: [statusId], references: [id])
  sprint   Sprint?     @relation(fields: [sprintId], references: [id])
  assignee User?       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator  User        @relation("TaskCreator", fields: [creatorId], references: [id])
  comments TaskComment[]

  @@index([listId])
  @@index([statusId])
  @@index([assigneeId])
  @@index([sprintId])
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId])
}

model Sprint {
  id        String    @id @default(cuid())
  name      String
  goal      String?
  startDate DateTime?
  endDate   DateTime?
  status    String    @default("planning")
  order     Int       @default(0)
  spaceId   String
  createdAt DateTime  @default(now())

  space Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([spaceId])
}

model Objective {
  id          String    @id @default(cuid())
  title       String
  description String?
  status      String    @default("on_track")
  ownerId     String?
  dueDate     DateTime?
  order       Int       @default(0)
  spaceId     String
  createdAt   DateTime  @default(now())

  space      Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  owner      User?      @relation(fields: [ownerId], references: [id])
  keyResults KeyResult[]

  @@index([spaceId])
}

model KeyResult {
  id          String   @id @default(cuid())
  title       String
  current     Float    @default(0)
  target      Float    @default(100)
  unit        String   @default("%")
  order       Int      @default(0)
  objectiveId String
  createdAt   DateTime @default(now())

  objective Objective @relation(fields: [objectiveId], references: [id], onDelete: Cascade)

  @@index([objectiveId])
}

model CanvasCard {
  id        String   @id @default(cuid())
  content   String
  block     String
  color     String   @default("#fef9c3")
  order     Int      @default(0)
  spaceId   String
  createdAt DateTime @default(now())

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
}

model RetroCard {
  id        String   @id @default(cuid())
  content   String
  column    String
  votes     Int      @default(0)
  order     Int      @default(0)
  authorId  String
  spaceId   String
  createdAt DateTime @default(now())

  space  Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])

  @@index([spaceId])
}
